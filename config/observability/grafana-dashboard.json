{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source — use Google Managed Prometheus, Prometheus, or Grafana Cloud",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Sympozium AI Agent Platform — Agent runs, token usage, tool invocations, and infrastructure health.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "title": "Total Agent Runs (1h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(sympozium_agent_runs_total[1h]))",
          "legendFormat": "runs"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.10 },
              { "color": "red", "value": 0.25 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "title": "Failure Rate (5m)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(sympozium_agent_runs_total{status=\"failed\"}[5m])) / sum(rate(sympozium_agent_runs_total[5m]))",
          "legendFormat": "failure rate"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100000 },
              { "color": "red", "value": 500000 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "title": "Output Tokens (1h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(gen_ai_usage_output_tokens_total[1h]))",
          "legendFormat": "tokens"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "title": "Gateway Ready",
      "type": "stat",
      "targets": [
        {
          "expr": "sympozium_gateway_ready",
          "legendFormat": "ready"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Agent Runs",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "title": "Agent Runs by Status",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(sympozium_agent_runs_total[5m])) by (status)",
          "legendFormat": "{{ status }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "title": "Agent Run Duration (P50 / P95 / P99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sympozium_agent_run_duration_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sympozium_agent_run_duration_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(sympozium_agent_run_duration_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 12,
      "title": "Agent Runs by Model",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(sympozium_agent_runs_total[5m])) by (model)",
          "legendFormat": "{{ model }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 13,
      "title": "Agent Runs by Instance",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(sympozium_agent_runs_total[5m])) by (instance_name)",
          "legendFormat": "{{ instance_name }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Token Usage & Cost",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 20,
      "title": "Input Tokens by Model",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(gen_ai_usage_input_tokens_total[5m])) by (model) * 300",
          "legendFormat": "{{ model }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 21,
      "title": "Output Tokens by Model",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(gen_ai_usage_output_tokens_total[5m])) by (model) * 300",
          "legendFormat": "{{ model }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 31 },
      "id": 22,
      "title": "Total Token Usage (24h) by Model",
      "type": "bargauge",
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(increase(gen_ai_usage_input_tokens_total[24h])) by (model)",
          "legendFormat": "{{ model }} (input)"
        },
        {
          "expr": "sum(increase(gen_ai_usage_output_tokens_total[24h])) by (model)",
          "legendFormat": "{{ model }} (output)"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 103,
      "title": "Tools & Skills",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "id": 30,
      "title": "Tool Invocations by Tool",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(sympozium_tool_invocations_total[5m])) by (tool)",
          "legendFormat": "{{ tool }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "id": 31,
      "title": "Skill Execution Duration (P50 / P95)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sympozium_skill_duration_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sympozium_skill_duration_bucket[5m])) by (le))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "id": 32,
      "title": "Tool Error Rate by Tool",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(sympozium_tool_invocations_total{status=\"error\"}[5m])) by (tool) / sum(rate(sympozium_tool_invocations_total[5m])) by (tool)",
          "legendFormat": "{{ tool }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 56 },
      "id": 104,
      "title": "Errors & Infrastructure",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 30 }, "unit": "short", "color": { "mode": "fixed", "fixedColor": "red" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 57 },
      "id": 40,
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(sympozium_errors_total[5m]))",
          "legendFormat": "errors/sec"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 57 },
      "id": 41,
      "title": "Web Endpoint Status",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sympozium_web_endpoint_serving",
          "legendFormat": "serving"
        },
        {
          "expr": "sum(rate(sympozium_web_endpoint_gateway_not_ready_total[5m]))",
          "legendFormat": "gateway not ready"
        },
        {
          "expr": "sum(rate(sympozium_web_endpoint_route_created_total[5m]))",
          "legendFormat": "routes created"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["sympozium", "ai-agents", "gcp", "vertex-ai"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Sympozium AI Agent Platform",
  "uid": "sympozium-overview",
  "version": 1
}
