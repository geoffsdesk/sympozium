---
import Base from '../layouts/Base.astro';

const posts = [
  {
    slug: 'why-gcp-only',
    title: 'Why I Forked Sympozium for 100% Google Cloud',
    date: '2026-03-15',
    excerpt: 'The original platform supports OpenAI, Anthropic, Azure, and Ollama. I stripped it all out and rebuilt for GKE + Gemini. Here\'s why a single-cloud bet makes sense for Kubernetes-native AI.',
    tags: ['architecture', 'gcp', 'strategy'],
  },
  {
    slug: 'hybrid-inference-gke',
    title: 'Hybrid Inference on GKE: Vertex AI + Gemma on TPU Nodes',
    date: '2026-03-14',
    excerpt: 'Running Gemma 3 (27B) on TPU v5e nodes alongside Vertex AI Gemini creates a cost/capability spectrum. The node-probe DaemonSet discovers local engines automatically.',
    tags: ['inference', 'tpu', 'gemma', 'vertexai'],
  },
  {
    slug: 'observability-two-paths',
    title: 'Two Observability Paths: Cloud Monitoring vs Prometheus/Grafana',
    date: '2026-03-13',
    excerpt: 'Not every team wants Cloud Monitoring. We added Google Managed Prometheus support with PodMonitoring CRDs, alerting rules, and a 14-panel Grafana dashboard.',
    tags: ['observability', 'grafana', 'prometheus', 'gmp'],
  },
  {
    slug: 'workload-identity-everywhere',
    title: 'Keyless Auth with Workload Identity Federation',
    date: '2026-03-12',
    excerpt: 'No service account JSON keys anywhere in this platform. Every pod authenticates to GCP via Workload Identity — Vertex AI, Pub/Sub, Secret Manager, Firestore, all of it.',
    tags: ['security', 'workload-identity', 'iam'],
  },
  {
    slug: 'google-chat-cards-v2',
    title: 'Building a Google Chat Bot with Cards v2 and Slash Commands',
    date: '2026-03-11',
    excerpt: 'The Google Chat channel implementation: Cards v2 responses, /ask, /status, /run, /help slash commands, threading, typing indicators, and interactive retry buttons.',
    tags: ['channels', 'google-chat', 'workspace'],
  },
];
---
<Base title="Blog">

<section class="page-header">
  <h1>Build Log</h1>
  <p>Notes on building a Kubernetes-native AI agent platform on Google Cloud.</p>
</section>

<section class="blog-list">
  <div class="blog-inner">
    {posts.map((post) => (
      <a href={`/blog/${post.slug}`} class="post-card">
        <div class="post-meta">
          <time>{post.date}</time>
          <div class="post-tags">
            {post.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
        <h2>{post.title}</h2>
        <p>{post.excerpt}</p>
        <span class="read-more">Read more →</span>
      </a>
    ))}
  </div>
</section>

<style>
  .page-header { padding: 80px 24px 40px; text-align: center; background: radial-gradient(ellipse at 50% 0%, rgba(66,133,244,0.06) 0%, transparent 70%); }
  .page-header h1 { font-size: 48px; font-weight: 800; letter-spacing: -1px; }
  .page-header p { color: var(--text-muted); margin-top: 12px; font-size: 18px; }

  .blog-list { padding: 40px 24px 80px; }
  .blog-inner { max-width: 760px; margin: 0 auto; }

  .post-card { display: block; text-decoration: none; color: var(--text); background: var(--surface-2); border: 1px solid var(--border); border-radius: 12px; padding: 28px 32px; margin-bottom: 16px; transition: border-color 0.15s, transform 0.15s; }
  .post-card:hover { border-color: rgba(66,133,244,0.4); transform: translateY(-2px); }

  .post-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
  .post-meta time { font-size: 13px; color: var(--text-muted); }
  .post-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag { font-size: 11px; font-weight: 600; color: var(--gcp-blue); background: rgba(66,133,244,0.1); padding: 2px 8px; border-radius: 4px; }

  .post-card h2 { font-size: 22px; font-weight: 700; line-height: 1.3; margin-bottom: 8px; }
  .post-card p { font-size: 14px; line-height: 1.6; color: var(--text-muted); }
  .read-more { display: inline-block; margin-top: 12px; font-size: 13px; font-weight: 600; color: var(--gcp-blue); }
</style>

</Base>
